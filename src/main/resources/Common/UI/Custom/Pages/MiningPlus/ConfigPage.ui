$C = "../../Common.ui";

$C.@PageOverlay {}

$C.@DecoratedContainer {
  Anchor: (Width: 500, Height: 650);

  #Title {
    Group {
      $C.@Title { @Text = "Mining+ Config"; }
    }
  }

  #Content {
    Group {
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Padding: (Full: 12);

      // --- Status overview ---
      Group {
        LayoutMode: Left;
        Padding: (Full: 6);
        Background: #000000(0.2);

        Group {
          LayoutMode: Top;
          FlexWeight: 1;
          Padding: (Full: 4);

          Label #StatusLine1 {
            Text: "Status: Enabled";
            Style: (TextColor: #55ff55, FontSize: 13);
          }

          Label #StatusLine2 {
            Text: "Mode: Ores Only | Key: None | Max: 64 | Depth: 32";
            Style: (TextColor: #96a9be, FontSize: 12);
          }
        }

        TextButton #ToggleBtn {
          Anchor: (Width: 110, Height: 36);
          Style: $C.@DefaultTextButtonStyle;
          Text: "Disable";
        }
      }

      // --- Separator ---
      Group { Anchor: (Height: 1); Padding: (Horizontal: 6); Background: #ffffff(0.1); }

      // --- Activation Key ---
      Group {
        LayoutMode: Top;
        Padding: (Left: 6, Top: 8);

        Label {
          Anchor: (Bottom: 6);
          Text: "Activation Key";
          Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true);
        }

        $C.@CheckBoxWithLabel #ActivationKeyNone {
          @Text = "None (always active)";
          @Checked = false;
        }

        $C.@CheckBoxWithLabel #ActivationKeyCrouch {
          @Text = "Crouch (Default: LEFT CTRL)";
          @Checked = false;
        }

        $C.@CheckBoxWithLabel #ActivationKeyWalk {
          @Text = "Walk / Sneak (Default: LEFT ALT)";
          @Checked = false;
        }

        Group {
          LayoutMode: Left;
          Padding: (Top: 6);

          TextButton #SaveActivation {
            Anchor: (Width: 180, Height: 28);
            Style: $C.@DefaultTextButtonStyle;
            Text: "Save Activation Key";
          }
        }
      }

      // --- Separator ---
      Group { Anchor: (Height: 1); Padding: (Horizontal: 6, Top: 6); Background: #ffffff(0.1); }

      // --- Mining Mode ---
      Label {
        Padding: (Left: 6, Top: 10, Bottom: 6);
        Text: "Mining Mode";
        Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true);
      }

      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Bottom: 8);

        TextButton #PatFreeform {
          Anchor: (Width: 130, Height: 28);
          Style: $C.@DefaultTextButtonStyle;
          Text: "Ores Only";
        }
      }

      // --- Separator ---
      Group { Anchor: (Height: 1); Padding: (Horizontal: 6); Background: #ffffff(0.1); }

      // --- Tunnel Patterns ---
      Label {
        Padding: (Left: 6, Top: 10, Bottom: 6);
        Text: "Tunnel Patterns";
        Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true);
      }

      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Bottom: 8);

        TextButton #PatTunnel1x1 {
          Anchor: (Width: 100, Height: 28);
          Style: $C.@DefaultTextButtonStyle;
          Text: "Tunnel 1x1";
        }

        Group { Anchor: (Width: 8); }

        TextButton #PatTunnel2x1 {
          Anchor: (Width: 100, Height: 28);
          Style: $C.@DefaultTextButtonStyle;
          Text: "Tunnel 2x1";
        }

        Group { Anchor: (Width: 8); }

        TextButton #PatTunnel3x3 {
          Anchor: (Width: 100, Height: 28);
          Style: $C.@DefaultTextButtonStyle;
          Text: "Tunnel 3x3";
        }
      }

      // --- Separator ---
      Group { Anchor: (Height: 1); Padding: (Horizontal: 6); Background: #ffffff(0.1); }

      // --- Area Patterns ---
      Label {
        Padding: (Left: 6, Top: 10, Bottom: 6);
        Text: "Area Patterns";
        Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true);
      }

      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Bottom: 8);

        TextButton #PatCube3x3 {
          Anchor: (Width: 100, Height: 28);
          Style: $C.@DefaultTextButtonStyle;
          Text: "3x3x3 Cube";
        }

        Group { Anchor: (Width: 8); }

        TextButton #PatCube5x5 {
          Anchor: (Width: 100, Height: 28);
          Style: $C.@DefaultTextButtonStyle;
          Text: "5x5x5 Cube";
        }
      }

      // --- Separator ---
      Group { Anchor: (Height: 1); Padding: (Horizontal: 6); Background: #ffffff(0.1); }

      // --- Max blocks ---
      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Top: 10, Bottom: 6);

        Label {
          FlexWeight: 1;
          Text: "Max Blocks";
          Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true);
        }

        Label #MaxBlocksLabel {
          Anchor: (Width: 40);
          Text: "64";
          Style: (TextColor: #E8A93B, FontSize: 14, HorizontalAlignment: Center);
        }
      }

      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Bottom: 8);

        TextButton #MaxBlocks16 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "16"; }
        Group { Anchor: (Width: 8); }
        TextButton #MaxBlocks32 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "32"; }
        Group { Anchor: (Width: 8); }
        TextButton #MaxBlocks64 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "64"; }
        Group { Anchor: (Width: 8); }
        TextButton #MaxBlocks128 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "128"; }
      }

      // --- Separator ---
      Group { Anchor: (Height: 1); Padding: (Horizontal: 6); Background: #ffffff(0.1); }

      // --- Depth ---
      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Top: 10, Bottom: 6);

        Label {
          FlexWeight: 1;
          Text: "Depth / Search Distance";
          Style: (TextColor: #96a9be, FontSize: 14, RenderBold: true);
        }

        Label #DepthLabel {
          Anchor: (Width: 40);
          Text: "32";
          Style: (TextColor: #E8A93B, FontSize: 14, HorizontalAlignment: Center);
        }
      }

      Group {
        LayoutMode: Left;
        Padding: (Left: 6, Bottom: 8);

        TextButton #Depth8 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "8"; }
        Group { Anchor: (Width: 8); }
        TextButton #Depth16 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "16"; }
        Group { Anchor: (Width: 8); }
        TextButton #Depth32 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "32"; }
        Group { Anchor: (Width: 8); }
        TextButton #Depth64 { Anchor: (Width: 70, Height: 28); Style: $C.@DefaultTextButtonStyle; Text: "64"; }
      }

    }
  }
}

$C.@BackButton {}
